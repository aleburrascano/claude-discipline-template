#!/usr/bin/env sh
# pre-commit: lightweight checks before commit.
# Note: full verification belongs in /verify-end-to-end (slower); pre-commit stays fast.

# 1. Prevent commits of files matching obviously sensitive patterns
SENSITIVE="$(git diff --cached --name-only 2>/dev/null | grep -E '(^|/)\.env($|\.)|(^|/)secrets/|\.(pem|key|p12|pfx)$' || true)"
if [ -n "$SENSITIVE" ]; then
  echo "❌ pre-commit: refusing to commit sensitive files:"
  echo "$SENSITIVE"
  echo "If intentional, use git commit --no-verify (and update .gitignore)."
  exit 1
fi

# 2. (Optional) ruff format check on staged Python files
STAGED_PY="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep '\.py$' || true)"
if [ -n "$STAGED_PY" ] && command -v uv >/dev/null 2>&1 && [ -f services/api/pyproject.toml ]; then
  cd services/api || exit 0
  echo "$STAGED_PY" | sed 's|^services/api/||' | xargs uv run --quiet ruff format --check 2>&1 || {
    echo "⚠️  pre-commit: ruff format check failed. Run: cd services/api && uv run ruff format"
    # Soft warn — don't block
  }
fi

exit 0
