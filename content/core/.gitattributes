# Normalize line endings; let git store LF in repo, check out platform-appropriate
* text=auto eol=lf

# Force LF for shell scripts (hooks)
*.sh           text eol=lf
*.bash         text eol=lf

# Force CRLF for Windows scripts
*.bat          text eol=crlf
*.cmd          text eol=crlf
*.ps1          text eol=crlf

# Binary files
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.mp3          binary
*.mp4          binary
*.wav          binary
*.flac         binary
*.pdf          binary
*.zip          binary
*.tgz          binary

# Generated / autogenerated files (excluded from diffs by default)
package-lock.json   linguist-generated=true
yarn.lock           linguist-generated=true
pnpm-lock.yaml      linguist-generated=true
poetry.lock         linguist-generated=true
uv.lock             linguist-generated=true
